# .env for desktop-scripts/setup_desktop.sh
# Edit these values for your machine. Do not commit secrets.

# Base paths ok
FZL_BASE_PATH=/home/wgn/WORKING
FZL_PROGSATIVOS_DIR=$_BASE_PATH/progsativos

# Android ok
FZL_ANDROID_SDK_HOME=$_PROGSATIVOS_DIR/Android/Sdk
FZL_ANDROID_SDK_ROOT=$ANDROID_SDK_HOME
FZL_ANDROID_HOME=$ANDROID_SDK_HOME
FZL_ANDROID_STUDIO_HOME=$_PROGSATIVOS_DIR/Android/android-studio-panda2-linux

# scrcpy?
FZL_SCRCPY_HOME=$_PROGSATIVOS_DIR/Android/scrcpy-linux-x86_64-v3.3.4

# Eclipse
FZL_ECLIPSE_JEE_HOME=$_PROGSATIVOS_DIR/ides/eclipse/eclipse-jee-2026-03-R-linux-gtk-x86_64
FZL_ECLIPSE_EMBEDCPP_HOME=$_PROGSATIVOS_DIR//ides/eclipse/eclipse-embedcpp-2026-03-R-linux-gtk-x86_64
FZL_ECLIPSE_PHP_HOME=$_PROGSATIVOS_DIR/ides/eclipse/eclipse-php-2026-03-R-linux-gtk-x86_64
FZL_ECLIPSE_MODELLING_HOME=$_PROGSATIVOS_DIR/ides/eclipse/eclipse-modeling-2026-03-R-linux-gtk-x86_64

# JetBrains
FZL_INTELLIJ_HOME=$_PROGSATIVOS_DIR/ides/idea-IU-252.23892.409

# AppImages and tools
FZL_BRUNO_AppImage=$_PROGSATIVOS_DIR/tools/bruno_3.2.0_x86_64_linux.AppImage
FZL_ZOTERO_HOME=$_PROGSATIVOS_DIR/research/Zotero_linux-x86_64
FZL_TELEGRAM_HOME=$_PROGSATIVOS_DIR/Telegram

# Java JDKs
FZL_JAVA_21_TEMURIM_HOME=$_PROGSATIVOS_DIR/javasdks/temurim/jdk-21.0.8+9
FZL_JAVA_17_TEMURIM_HOME=$_PROGSATIVOS_DIR/javasdks/temurim/jdk-17.0.16+8
FZL_JAVA_11_TEMURIM_HOME=$_PROGSATIVOS_DIR/javasdks/temurim/jdk-11.0.28+6

# DB tools
FZL_SQUIRREL_SQL_HOME=$_PROGSATIVOS_DIR/ides-dbs/SQuirreLSQL/squirrelsql-5.0.0-optional
FZL_DBEAVER_HOME=$_PROGSATIVOS_DIR/ides/ides-dbs/dbeaver

