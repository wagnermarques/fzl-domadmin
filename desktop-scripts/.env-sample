# Sample .env for desktop-scripts/setup_desktop.sh
# Copy this to .env and customize for each machine.

# Base paths
_BASE_PATH=/home/youruser/WORKING
_PROGSATIVOS_DIR=/home/youruser/WORKING/Progsativos

# Emacs customization
_FZL_EMACS_HOME=/home/youruser/WORKING/Projects-Srcs/Projects-Srcs-Desktop/fzl-emacs

# Android
ANDROID_STUDIO_HOME=/home/youruser/WORKING/Progsativos/ides/android/android-studio-panda1-linux/android-studio
ANDROID_SDK_HOME=/home/youruser/WORKING/Progsativos/android-sdk

# scrcpy
_SCRCPY_HOME=/home/youruser/WORKING/Progsativos/Android/scrcpy-linux-x86_64-v3.3.4

# Eclipse
_ECLIPSE_JEE_HOME=/home/youruser/WORKING/Progsativos/ides/eclipse/eclipse-jee-2026-03-R-linux-gtk-x86_64
_ECLIPSE_EMBEDCPP_HOME=/home/youruser/WORKING/Progsativos/ides/eclipse/eclipse-embedcpp-2026-03-R-linux-gtk-x86_64
_ECLIPSE_PHP_HOME=/home/youruser/WORKING/Progsativos/ides/eclipse/eclipse-php-2026-03-R-linux-gtk-x86_64
_ECLIPSE_MODELLING_HOME=/home/youruser/WORKING/Progsativos/ides/eclipse/eclipse-modeling-2026-03-R-linux-gtk-x86_64

# JetBrains
_INTELLIJ_HOME=/home/youruser/WORKING/Progsativos/ides/idea-IU-252.23892.409

# AppImages and tools
_BRUNO_AppImage=/home/youruser/WORKING/Progsativos/tools/bruno_3.2.0_x86_64_linux.AppImage
ZOTERO_HOME=/home/youruser/WORKING/Progsativos/research/Zotero_linux-x86_64
TELEGRAM_HOME=/home/youruser/WORKING/Progsativos/Telegram

# Java JDKs
JAVA_21_TEMURIM_HOME=/home/youruser/WORKING/Progsativos/javasdks/temurim/jdk-21.0.8+9
JAVA_17_TEMURIM_HOME=/home/youruser/WORKING/Progsativos/javasdks/temurim/jdk-17.0.16+8
JAVA_11_TEMURIM_HOME=/home/youruser/WORKING/Progsativos/javasdks/temurim/jdk-11.0.28+6

# DB tools
_SQUIRREL_SQL_HOME=/home/youruser/WORKING/Progsativos/ides-dbs/SQuirreLSQL/squirrelsql-5.0.0-optional
_DBEAVER_HOME=/home/youruser/WORKING/Progsativos/ides/ides-dbs/dbeaver

# Optional: ANDROID_SDK_ROOT and ANDROID_HOME are set from ANDROID_SDK_HOME by the script
# ANDROID_SDK_ROOT=/path/to/sdk
# ANDROID_HOME=/path/to/sdk
